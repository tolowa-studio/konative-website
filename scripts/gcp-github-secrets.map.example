# GCP Secret Manager (project spokanewire) → GitHub Actions for konative-website
# Copy to gcp-github-secrets.map and adjust names to match your vault.
#
# Format:
#   secret:GITHUB_NAME=gcp-secret-id
#   variable:GITHUB_NAME=gcp-secret-id
#
# The sync script tries alternate GCP names (comma-separated) when the first is missing.

secret:SUPABASE_ACCESS_TOKEN=konative-supabase-access-token,supabase-access-token,konative-supabase-access-token

# Workload Identity Federation (non-secret resource names; stored as GCP secrets in some setups)
variable:GCP_WIF_PROVIDER=konative-github-wif-provider,github-wif-provider
variable:GCP_SERVICE_ACCOUNT=konative-github-actions-service-account,github-actions-service-account

# Optional: mirror other konative keys used by refresh-tiles / Vercel bootstrap
# secret:CLOUDFLARE_ACCOUNT_ID=konative-cloudflare-account-id
# secret:R2_ACCESS_KEY_ID=konative-r2-access-key-id
# secret:R2_SECRET_ACCESS_KEY=konative-r2-secret-access-key
# secret:R2_BUCKET_NAME=konative-r2-bucket-name
# secret:R2_PUBLIC_URL=konative-r2-public-url
