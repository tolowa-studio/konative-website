# Supabase (analytics + /api/v1/*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sanity (CMS + Studio at /studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_editor_token_with_write
# Optional — enables Unsplash image picker tab in Studio (https://www.sanity.io/docs/install-the-unsplash-asset-source)
SANITY_STUDIO_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Builder.io (optional — visual routes at /builder/* only; production / is built in app, not Builder)
NEXT_PUBLIC_BUILDER_API_KEY=your_public_builder_api_key
# Optional server-only — draft / private-model content for Builder routes (never NEXT_PUBLIC_*)
# https://www.builder.io/c/docs/preview-private-models
BUILDER_PRIVATE_API_KEY=your_builder_private_api_key

# Site
NEXT_PUBLIC_SITE_URL=https://konative.com

# Vercel Blob (optional legacy assets)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Konative <team@konative.com>
RESEND_TO=your_intake_inbox@example.com

# CRM intake automation — n8n webhook that creates/updates the person,
# company, opportunity, source campaign, and follow-up task in Twenty.
TWENTY_INTAKE_WEBHOOK_URL=https://your-n8n.example.com/webhook/konative-intake
TWENTY_INTAKE_WEBHOOK_TOKEN=your_random_bearer_token

# Newsletter — Ghost (shared Tolowa Studio Ghost instance on Railway)
# See STRATEGY.md B6. Beehiiv was dropped 2026-05-23.
# Server-only (member create via Admin API, server-component archive reads):
GHOST_URL=https://ghost-production-fd16.up.railway.app
GHOST_ADMIN_API_KEY=your_ghost_admin_api_key
GHOST_CONTENT_API_KEY=your_ghost_content_api_key
# Public-facing duplicates (blog post pages render client-side):
NEXT_PUBLIC_GHOST_URL=https://ghost-production-fd16.up.railway.app
NEXT_PUBLIC_GHOST_CONTENT_API_KEY=your_ghost_content_api_key
# Konative Dispatch newsletter identity (defaults baked into web/src/lib/ghost.ts;
# override per-environment if the Ghost instance changes):
KONATIVE_NEWSLETTER_ID=6a1115c22d98680001cb1028
KONATIVE_NEWSLETTER_SLUG=konative-dispatch

# News ingest cron / manual trigger (/api/ingest-news)
NEWS_INGEST_TOKEN=your_random_secret

# Strategy snapshot (STRATEGY.md B11) — read by weekly review / future autonomous
# agent. Bearer token via Authorization or x-strategy-token header.
# GET /api/admin/strategy-snapshot
STRATEGY_SNAPSHOT_TOKEN=your_random_secret

# Google Search Console — set once the property is verified (meta-tag method).
# GOOGLE_SITE_VERIFICATION=abc123

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
